NODE_ENV=development
PORT=4002
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/healthlink-appointments
JWT_ACCESS_SECRET=replace_with_auth_service_access_secret
CORS_ORIGIN=http://localhost:3000
ALLOW_DOCTOR_FALLBACK=false
AUTH_SERVICE_URL=http://localhost:4000
INTERNAL_SERVICE_API_KEY=healthlink-internal-key
DOCTOR_SERVICE_URL=http://localhost:3003
PAYMENT_SERVICE_URL=http://localhost:3004
NOTIFICATION_SERVICE_URL=http://localhost:4007
REQUEST_TIMEOUT_MS=5000
